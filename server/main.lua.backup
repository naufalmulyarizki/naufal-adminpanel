local QBCore = exports['qb-core']:GetCoreObject()
local AdminLogs = {}

-- Helper function untuk debug
local function Debug(...)
    if Config.Debug then
        print('[AdminPanel:Server]', ...)
    end
end

-- Get player's highest permission level
local function GetPlayerPermissionLevel(source)
    local Player = QBCore.Functions.GetPlayer(source)
    if not Player then return 0 end
    
    -- Check for ace command (usually god/owner)
    if IsPlayerAceAllowed(source, 'command') then
        return Config.PermissionLevels['god'] or 3
    end
    
    -- Check each permission level from highest to lowest
    local highestLevel = 0
    for permission, level in pairs(Config.PermissionLevels) do
        if QBCore.Functions.HasPermission(source, permission) then
            if level > highestLevel then
                highestLevel = level
            end
        end
    end
    
    return highestLevel
end

-- Check if player has specific permission level
local function HasPermissionLevel(source, requiredPermission)
    local playerLevel = GetPlayerPermissionLevel(source)
    local requiredLevel = Config.PermissionLevels[requiredPermission] or 0
    return playerLevel >= requiredLevel
end

-- Check if player has admin permission (legacy function for basic access)
local function HasPermission(source, permission)
    permission = permission or Config.RequiredPermission
    local Player = QBCore.Functions.GetPlayer(source)
    if not Player then return false end
    
    return QBCore.Functions.HasPermission(source, permission) or IsPlayerAceAllowed(source, 'command')
end

-- Check feature permission
local function HasFeaturePermission(source, category, feature)
    if not Config.FeaturePermissions[category] then return false end
    if not Config.FeaturePermissions[category][feature] then return false end
    
    local requiredPermission = Config.FeaturePermissions[category][feature]
    return HasPermissionLevel(source, requiredPermission)
end

-- Get all allowed features for a player
local function GetPlayerFeatures(source)
    local features = {}
    local playerLevel = GetPlayerPermissionLevel(source)
    
    for category, categoryFeatures in pairs(Config.FeaturePermissions) do
        features[category] = {}
        for feature, permission in pairs(categoryFeatures) do
            local requiredLevel = Config.PermissionLevels[permission] or 0
            features[category][feature] = playerLevel >= requiredLevel
        end
    end
    
    return features
end

-- Get admin name
local function GetAdminName(source)
    local Player = QBCore.Functions.GetPlayer(source)
    if Player then
        return Player.PlayerData.charinfo.firstname .. ' ' .. Player.PlayerData.charinfo.lastname .. ' (ID: ' .. source .. ')'
    end
    return 'Unknown Admin (ID: ' .. source .. ')'
end

-- Get target name
local function GetTargetName(targetId)
    local Player = QBCore.Functions.GetPlayer(tonumber(targetId))
    if Player then
        return Player.PlayerData.charinfo.firstname .. ' ' .. Player.PlayerData.charinfo.lastname .. ' (ID: ' .. targetId .. ')'
    end
    return 'Unknown Player (ID: ' .. targetId .. ')'
end

-- Log admin action
local function LogAction(adminSource, action, targetId, details, logType)
    logType = logType or 'info'
    
    local log = {
        id = #AdminLogs + 1,
        timestamp = os.date('%Y-%m-%d %H:%M:%S'),
        type = logType,
        action = action,
        admin = GetAdminName(adminSource),
        target = targetId and GetTargetName(targetId) or nil,
        details = details or ''
    }
    
    table.insert(AdminLogs, 1, log) -- Insert at beginning
    
    -- Limit logs
    if #AdminLogs > Config.Logging.maxLogs then
        table.remove(AdminLogs) -- Remove oldest
    end
    
    Debug('Action logged:', action, 'by', log.admin)
    
    -- Discord logging
    if Config.DiscordWebhook and Config.DiscordWebhook ~= '' then
        SendDiscordLog(log)
    end
    
    -- Database logging
    if Config.Logging.saveToDatabase then
        SaveLogToDatabase(log)
    end
end

-- Send discord webhook
function SendDiscordLog(log)
    local color = Config.DiscordColors[log.type] or Config.DiscordColors.info
    
    local embed = {
        {
            ['title'] = 'Admin Panel Log',
            ['description'] = log.action,
            ['color'] = color,
            ['fields'] = {
                { ['name'] = 'Admin', ['value'] = log.admin, ['inline'] = true },
                { ['name'] = 'Target', ['value'] = log.target or 'N/A', ['inline'] = true },
                { ['name'] = 'Details', ['value'] = log.details or 'N/A', ['inline'] = false },
            },
            ['footer'] = {
                ['text'] = 'Admin Panel | ' .. log.timestamp
            }
        }
    }
    
    PerformHttpRequest(Config.DiscordWebhook, function(err, text, headers) end, 'POST', json.encode({ embeds = embed }), { ['Content-Type'] = 'application/json' })
end

-- Save log to database
function SaveLogToDatabase(log)
    MySQL.insert('INSERT INTO adminpanel_logs (timestamp, type, action, admin, target, details) VALUES (?, ?, ?, ?, ?, ?)', {
        log.timestamp,
        log.type,
        log.action,
        log.admin,
        log.target or '',
        log.details or ''
    })
end

-- Get all players data
local function GetPlayersData()
    local players = {}
    local qbPlayers = QBCore.Functions.GetPlayers()
    
    for _, playerId in ipairs(qbPlayers) do
        local Player = QBCore.Functions.GetPlayer(playerId)
        if Player then
            table.insert(players, {
                id = playerId,
                name = Player.PlayerData.charinfo.firstname .. ' ' .. Player.PlayerData.charinfo.lastname,
                license = Player.PlayerData.license or 'Unknown',
                money = Player.PlayerData.money.cash or 0,
                bank = Player.PlayerData.money.bank or 0
            })
        end
    end
    
    return players
end

-- Callbacks
QBCore.Functions.CreateCallback('adminpanel:server:hasPermission', function(source, cb)
    local hasAccess = HasPermission(source)
    local features = hasAccess and GetPlayerFeatures(source) or {}
    cb(hasAccess, features)
end)

QBCore.Functions.CreateCallback('adminpanel:server:getPlayers', function(source, cb)
    if not HasPermission(source) then
        cb({})
        return
    end
    cb(GetPlayersData())
end)

QBCore.Functions.CreateCallback('adminpanel:server:getFeatures', function(source, cb)
    if not HasPermission(source) then
        cb({})
        return
    end
    cb(GetPlayerFeatures(source))
end)

QBCore.Functions.CreateCallback('adminpanel:server:getLogs', function(source, cb)
    if not HasPermission(source) then
        cb({})
        return
    end
    cb(AdminLogs)
end)

-- Kick Player
RegisterNetEvent('adminpanel:server:kickPlayer', function(targetId, reason)
    local src = source
    if not HasPermission(src) then return end
    
    targetId = tonumber(targetId)
    local Target = QBCore.Functions.GetPlayer(targetId)
    
    if Target then
        local targetName = GetTargetName(targetId)
        DropPlayer(targetId, reason or Config.Notifications.kickMessage)
        LogAction(src, 'Player Kicked', targetId, 'Reason: ' .. (reason or 'No reason'), 'warning')
        TriggerClientEvent('adminpanel:client:notify', src, 'Player ' .. targetName .. ' has been kicked', 'success')
        Debug('Player kicked:', targetId, 'Reason:', reason)
    else
        TriggerClientEvent('adminpanel:client:notify', src, 'Player not found', 'error')
    end
end)

-- Ban Player
RegisterNetEvent('adminpanel:server:banPlayer', function(targetId, reason, duration)
    local src = source
    if not HasPermission(src) then return end
    
    targetId = tonumber(targetId)
    duration = tonumber(duration) or 0
    local Target = QBCore.Functions.GetPlayer(targetId)
    
    if Target then
        local targetName = GetTargetName(targetId)
        local banExpiry = duration > 0 and os.time() + (duration * 60) or 2147483647 -- 2038 for permanent
        
        -- Use QBCore ban system
        local banData = {
            name = Target.PlayerData.charinfo.firstname .. ' ' .. Target.PlayerData.charinfo.lastname,
            license = Target.PlayerData.license,
            discord = Target.PlayerData.discord or '',
            ip = Target.PlayerData.ip or '',
            reason = reason or Config.Notifications.banMessage,
            expire = banExpiry,
            bannedby = GetAdminName(src)
        }
        
        -- Insert ban to database
        MySQL.insert('INSERT INTO bans (name, license, discord, ip, reason, expire, bannedby) VALUES (?, ?, ?, ?, ?, ?, ?)', {
            banData.name,
            banData.license,
            banData.discord,
            banData.ip,
            banData.reason,
            banData.expire,
            banData.bannedby
        })
        
        DropPlayer(targetId, banData.reason)
        
        local durationText = duration > 0 and (duration .. ' minutes') or 'Permanent'
        LogAction(src, 'Player Banned', targetId, 'Duration: ' .. durationText .. ', Reason: ' .. (reason or 'No reason'), 'error')
        TriggerClientEvent('adminpanel:client:notify', src, 'Player ' .. targetName .. ' has been banned', 'success')
        Debug('Player banned:', targetId, 'Duration:', duration, 'Reason:', reason)
    else
        TriggerClientEvent('adminpanel:client:notify', src, 'Player not found', 'error')
    end
end)

-- Give Money
RegisterNetEvent('adminpanel:server:giveMoney', function(targetId, moneyType, amount)
    local src = source
    if not HasPermission(src) then return end
    
    targetId = tonumber(targetId)
    amount = tonumber(amount)
    
    if not amount or amount <= 0 then
        TriggerClientEvent('adminpanel:client:notify', src, 'Invalid amount', 'error')
        return
    end
    
    local Target = QBCore.Functions.GetPlayer(targetId)
    
    if Target then
        local targetName = GetTargetName(targetId)
        
        if moneyType == 'money' or moneyType == 'cash' then
            Target.Functions.AddMoney('cash', amount, 'admin-panel-give')
        elseif moneyType == 'bank' then
            Target.Functions.AddMoney('bank', amount, 'admin-panel-give')
        end
        
        LogAction(src, 'Money Given', targetId, 'Type: ' .. moneyType .. ', Amount: $' .. amount, 'info')
        TriggerClientEvent('adminpanel:client:notify', src, 'Given $' .. amount .. ' ' .. moneyType .. ' to ' .. targetName, 'success')
        TriggerClientEvent('adminpanel:client:notify', targetId, 'You received $' .. amount .. ' ' .. moneyType .. ' from admin', 'success')
        Debug('Money given:', targetId, moneyType, amount)
        
        -- Update players list
        TriggerClientEvent('adminpanel:client:updatePlayers', src, GetPlayersData())
    else
        TriggerClientEvent('adminpanel:client:notify', src, 'Player not found', 'error')
    end
end)

-- Give Item
RegisterNetEvent('adminpanel:server:giveItem', function(targetId, itemName, quantity)
    local src = source
    if not HasPermission(src) then return end
    
    targetId = tonumber(targetId)
    quantity = tonumber(quantity) or 1
    
    if quantity <= 0 then
        TriggerClientEvent('adminpanel:client:notify', src, 'Invalid quantity', 'error')
        return
    end
    
    local Target = QBCore.Functions.GetPlayer(targetId)
    
    if Target then
        local targetName = GetTargetName(targetId)
        local success = Target.Functions.AddItem(itemName, quantity)
        
        if success then
            TriggerClientEvent('inventory:client:ItemBox', targetId, QBCore.Shared.Items[itemName], 'add', quantity)
            LogAction(src, 'Item Given', targetId, 'Item: ' .. itemName .. ', Quantity: ' .. quantity, 'info')
            TriggerClientEvent('adminpanel:client:notify', src, 'Given ' .. quantity .. 'x ' .. itemName .. ' to ' .. targetName, 'success')
            TriggerClientEvent('adminpanel:client:notify', targetId, 'You received ' .. quantity .. 'x ' .. itemName .. ' from admin', 'success')
            Debug('Item given:', targetId, itemName, quantity)
        else
            TriggerClientEvent('adminpanel:client:notify', src, 'Failed to give item (inventory full?)', 'error')
        end
    else
        TriggerClientEvent('adminpanel:client:notify', src, 'Player not found', 'error')
    end
end)

-- Teleport Player
RegisterNetEvent('adminpanel:server:teleportPlayer', function(targetId, coords, heading)
    local src = source
    if not HasPermission(src) then return end
    
    targetId = tonumber(targetId)
    local Target = QBCore.Functions.GetPlayer(targetId)
    
    if Target then
        local targetName = GetTargetName(targetId)
        TriggerClientEvent('adminpanel:client:teleport', targetId, coords, heading)
        LogAction(src, 'Teleported Player', targetId, string.format('To: %.2f, %.2f, %.2f', coords.x, coords.y, coords.z), 'warning')
        TriggerClientEvent('adminpanel:client:notify', src, 'Teleported ' .. targetName, 'success')
        Debug('Player teleported:', targetId, coords.x, coords.y, coords.z)
    else
        TriggerClientEvent('adminpanel:client:notify', src, 'Player not found', 'error')
    end
end)

-- Log Action (from client)
RegisterNetEvent('adminpanel:server:logAction', function(action, targetId, details)
    local src = source
    if not HasPermission(src) then return end
    LogAction(src, action, targetId, details, 'info')
end)

-- Clear Logs
RegisterNetEvent('adminpanel:server:clearLogs', function()
    local src = source
    if not HasPermission(src) then return end
    
    local logCount = #AdminLogs
    AdminLogs = {}
    
    LogAction(src, 'Logs Cleared', nil, 'Cleared ' .. logCount .. ' logs', 'warning')
    TriggerClientEvent('adminpanel:client:notify', src, 'Logs cleared', 'success')
    Debug('Logs cleared by admin')
    
    -- Clear from database too
    if Config.Logging.saveToDatabase then
        MySQL.query('DELETE FROM adminpanel_logs')
    end
end)

-- Export Logs (save to file)
RegisterNetEvent('adminpanel:server:exportLogs', function(csv, filename)
    local src = source
    if not HasPermission(src) then return end
    
    if not csv or csv == '' then
        TriggerClientEvent('adminpanel:client:notify', src, 'No logs to export', 'error')
        return
    end
    
    -- Create logs directory if it doesn't exist
    local resourcePath = GetResourcePath(GetCurrentResourceName())
    local logsDir = resourcePath .. '/logs'
    
    -- Clean filename
    filename = filename or ('admin-logs-' .. os.time() .. '.csv')
    filename = filename:gsub('[^%w%-_%.%s]', '')
    
    local filePath = logsDir .. '/' .. filename
    
    -- Try to save the file
    local file = io.open(filePath, 'w')
    if file then
        file:write(csv)
        file:close()
        
        local adminName = GetPlayerName(src) or 'Unknown'
        LogAction(src, 'Logs Exported', nil, 'Exported logs to ' .. filename, 'info')
        TriggerClientEvent('adminpanel:client:notify', src, 'Logs exported to: ' .. filename, 'success')
        Debug('Logs exported by', adminName, 'to', filePath)
    else
        -- Try creating the logs directory first
        os.execute('mkdir "' .. logsDir .. '"')
        
        file = io.open(filePath, 'w')
        if file then
            file:write(csv)
            file:close()
            
            local adminName = GetPlayerName(src) or 'Unknown'
            LogAction(src, 'Logs Exported', nil, 'Exported logs to ' .. filename, 'info')
            TriggerClientEvent('adminpanel:client:notify', src, 'Logs exported to: ' .. filename, 'success')
            Debug('Logs exported by', adminName, 'to', filePath)
        else
            TriggerClientEvent('adminpanel:client:notify', src, 'Failed to export logs', 'error')
            Debug('Failed to save logs file:', filePath)
        end
    end
end)

-- Load logs from database on resource start
AddEventHandler('onResourceStart', function(resourceName)
    if GetCurrentResourceName() ~= resourceName then return end
    
    if Config.Logging.saveToDatabase then
        -- Create table if not exists
        MySQL.query([[
            CREATE TABLE IF NOT EXISTS adminpanel_logs (
                id INT AUTO_INCREMENT PRIMARY KEY,
                timestamp VARCHAR(50),
                type VARCHAR(20),
                action VARCHAR(100),
                admin VARCHAR(100),
                target VARCHAR(100),
                details TEXT,
                created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
            )
        ]])
        
        -- Load existing logs
        MySQL.query('SELECT * FROM adminpanel_logs ORDER BY id DESC LIMIT ?', { Config.Logging.maxLogs }, function(result)
            if result then
                for _, log in ipairs(result) do
                    table.insert(AdminLogs, {
                        id = log.id,
                        timestamp = log.timestamp,
                        type = log.type,
                        action = log.action,
                        admin = log.admin,
                        target = log.target,
                        details = log.details
                    })
                end
                Debug('Loaded', #AdminLogs, 'logs from database')
            end
        end)
    end
    
    print('^2[AdminPanel]^0 Resource started successfully!')
end)

-- Player joined - update admin panels
AddEventHandler('QBCore:Server:PlayerLoaded', function(Player)
    Citizen.SetTimeout(1000, function()
        local admins = QBCore.Functions.GetPlayers()
        for _, adminId in ipairs(admins) do
            if HasPermission(adminId) then
                TriggerClientEvent('adminpanel:client:updatePlayers', adminId, GetPlayersData())
            end
        end
    end)
end)

-- Player left - update admin panels
AddEventHandler('playerDropped', function(reason)
    local src = source
    Citizen.SetTimeout(1000, function()
        local admins = QBCore.Functions.GetPlayers()
        for _, adminId in ipairs(admins) do
            if HasPermission(adminId) then
                TriggerClientEvent('adminpanel:client:updatePlayers', adminId, GetPlayersData())
            end
        end
    end)
end)

-- ====================
-- WORLD CONTROLS
-- ====================

-- Set Weather
RegisterNetEvent('adminpanel:server:setWeather', function(weather)
    local src = source
    if not HasPermission(src) then return end
    
    -- Use qb-weathersync if available
    TriggerEvent('qb-weathersync:server:setWeather', weather)
    
    -- Fallback: set weather for all clients
    TriggerClientEvent('adminpanel:client:setWeather', -1, weather)
    
    LogAction(src, 'Set Weather', nil, 'Weather: ' .. weather, 'info')
    Debug('Weather set to:', weather)
end)

-- Set Time
RegisterNetEvent('adminpanel:server:setTime', function(hour, minute)
    local src = source
    if not HasPermission(src) then return end
    
    hour = tonumber(hour) or 12
    minute = tonumber(minute) or 0
    
    -- Use qb-weathersync if available
    TriggerEvent('qb-weathersync:server:setTime', hour, minute)
    
    -- Fallback: set time for all clients
    TriggerClientEvent('adminpanel:client:setTime', -1, hour, minute)
    
    LogAction(src, 'Set Time', nil, string.format('Time: %02d:%02d', hour, minute), 'info')
    Debug('Time set to:', hour, minute)
end)

-- Freeze Time
RegisterNetEvent('adminpanel:server:freezeTime', function(enabled)
    local src = source
    if not HasPermission(src) then return end
    
    -- Use qb-weathersync if available
    TriggerEvent('qb-weathersync:server:toggleFreeze', enabled)
    
    -- Fallback
    TriggerClientEvent('adminpanel:client:freezeTime', -1, enabled)
    
    LogAction(src, 'Freeze Time', nil, enabled and 'Enabled' or 'Disabled', 'info')
    Debug('Freeze time:', enabled)
end)

-- Blackout
RegisterNetEvent('adminpanel:server:setBlackout', function(enabled)
    local src = source
    if not HasPermission(src) then return end
    
    -- Use qb-weathersync if available
    TriggerEvent('qb-weathersync:server:setBlackout', enabled)
    
    -- Fallback
    TriggerClientEvent('adminpanel:client:setBlackout', -1, enabled)
    
    LogAction(src, 'Blackout', nil, enabled and 'Enabled' or 'Disabled', 'info')
    Debug('Blackout:', enabled)
end)

-- Revive Self
RegisterNetEvent('adminpanel:server:reviveSelf', function()
    local src = source
    if not HasPermission(src) then return end
    
    -- Use qb-ambulancejob revive
    TriggerClientEvent('hospital:client:Revive', src)
    
    LogAction(src, 'Revive Self', nil, 'Self revived', 'info')
    Debug('Admin revived self:', src)
end)

-- ====================
-- PLAYER ACTIONS
-- ====================

-- Clear Inventory (ox_inventory)
RegisterNetEvent('adminpanel:server:clearInventory', function(targetId)
    local src = source
    if not HasPermission(src) then return end
    
    targetId = tonumber(targetId)
    local Target = QBCore.Functions.GetPlayer(targetId)
    
    if Target then
        local targetName = GetTargetName(targetId)
        
        -- Try ox_inventory first
        local success = pcall(function()
            exports.ox_inventory:ClearInventory(targetId)
        end)
        
        -- Fallback to QBCore inventory clear
        if not success then
            local items = Target.PlayerData.items
            for slot, item in pairs(items) do
                if item then
                    Target.Functions.RemoveItem(item.name, item.amount, slot)
                end
            end
        end
        
        LogAction(src, 'Clear Inventory', targetId, 'Cleared inventory of ' .. targetName, 'warning')
        TriggerClientEvent('adminpanel:client:notify', src, 'Cleared inventory of ' .. targetName, 'success')
        TriggerClientEvent('adminpanel:client:notify', targetId, 'Your inventory has been cleared by an admin!', 'error')
        Debug('Inventory cleared:', targetId)
    else
        TriggerClientEvent('adminpanel:client:notify', src, 'Player not found', 'error')
    end
end)

-- Freeze Player
RegisterNetEvent('adminpanel:server:freezePlayer', function(targetId, frozen)
    local src = source
    if not HasPermission(src) then return end
    
    targetId = tonumber(targetId)
    local Target = QBCore.Functions.GetPlayer(targetId)
    
    if Target then
        local targetName = GetTargetName(targetId)
        TriggerClientEvent('adminpanel:client:freeze', targetId, frozen)
        
        local action = frozen and 'Frozen' or 'Unfrozen'
        LogAction(src, action .. ' Player', targetId, targetName .. ' was ' .. action:lower(), 'warning')
        TriggerClientEvent('adminpanel:client:notify', src, targetName .. ' has been ' .. action:lower(), 'success')
        Debug('Player ' .. action:lower() .. ':', targetId)
    else
        TriggerClientEvent('adminpanel:client:notify', src, 'Player not found', 'error')
    end
end)

