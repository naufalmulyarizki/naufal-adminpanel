-- Give Item to Player
RegisterNetEvent('adminpanel:server:giveItemToPlayer', function(targetId, item, amount)
    local src = source
    if not HasPermission(src) then return end
    
    targetId = tonumber(targetId)
    amount = tonumber(amount) or 1
    local Target = QBCore.Functions.GetPlayer(targetId)
    
    if Target then
        local targetName = GetTargetName(targetId)
        
        -- Try ox_inventory first, then qb-inventory
        if GetResourceState('ox_inventory') == 'started' then
            exports['ox_inventory']:AddItem(targetId, item, amount)
        else
            Target.Functions.AddItem(item, amount)
            TriggerClientEvent('inventory:client:ItemBox', targetId, QBCore.Shared.Items[item], 'add', amount)
        end
        
        LogAction(src, 'Give Item', targetId, 'Gave ' .. amount .. 'x ' .. item .. ' to ' .. targetName, 'info')
        TriggerClientEvent('adminpanel:client:notify', src, 'Gave ' .. amount .. 'x ' .. item .. ' to ' .. targetName, 'success')
        TriggerClientEvent('adminpanel:client:notify', targetId, 'You received ' .. amount .. 'x ' .. item, 'success')
    else
        TriggerClientEvent('adminpanel:client:notify', src, 'Player not found', 'error')
    end
end)

RegisterNetEvent('adminpanel:server:giveItemToAll', function(item, amount)
    local src = source
    if not HasPermission(src) then return end
    
    amount = tonumber(amount) or 1
    local players = QBCore.Functions.GetPlayers()
    local count = 0
    
    for _, playerId in ipairs(players) do
        local Target = QBCore.Functions.GetPlayer(playerId)
        if Target then
            if GetResourceState('ox_inventory') == 'started' then
                exports['ox_inventory']:AddItem(playerId, item, amount)
            else
                Target.Functions.AddItem(item, amount)
                TriggerClientEvent('inventory:client:ItemBox', playerId, QBCore.Shared.Items[item], 'add', amount)
            end
            TriggerClientEvent('adminpanel:client:notify', playerId, 'You received ' .. amount .. 'x ' .. item, 'success')
            count = count + 1
        end
    end
    
    LogAction(src, 'Give Item to All', nil, 'Gave ' .. amount .. 'x ' .. item .. ' to ' .. count .. ' players', 'success')
    TriggerClientEvent('adminpanel:client:notify', src, 'Gave ' .. amount .. 'x ' .. item .. ' to ' .. count .. ' players', 'success')
end)

-- Give Money to All Players
RegisterNetEvent('adminpanel:server:giveMoneyToAll', function(amount, moneyType)
    local src = source
    if not HasPermission(src) then return end
    
    amount = tonumber(amount) or 0
    moneyType = moneyType or 'money'
    local players = QBCore.Functions.GetPlayers()
    local count = 0
    
    for _, playerId in ipairs(players) do
        local Target = QBCore.Functions.GetPlayer(playerId)
        if Target then
            if moneyType == 'bank' then
                Target.Functions.AddMoney('bank', amount, 'admin-panel')
            else
                Target.Functions.AddMoney('cash', amount, 'admin-panel')
            end
            TriggerClientEvent('adminpanel:client:notify', playerId, 'You received $' .. amount .. ' (' .. moneyType .. ')', 'success')
            count = count + 1
        end
    end
    
    LogAction(src, 'Give Money to All', nil, 'Gave $' .. amount .. ' (' .. moneyType .. ') to ' .. count .. ' players', 'success')
    TriggerClientEvent('adminpanel:client:notify', src, 'Gave $' .. amount .. ' to ' .. count .. ' players', 'success')
end)

-- Make Player Drunk
RegisterNetEvent('adminpanel:server:makePlayerDrunk', function(targetId)
    local src = source
    if not HasPermission(src) then return end
    
    targetId = tonumber(targetId)
    local Target = QBCore.Functions.GetPlayer(targetId)
    
    if Target then
        local targetName = GetTargetName(targetId)
        TriggerClientEvent('adminpanel:client:makeDrunk', targetId)
        
        LogAction(src, 'Make Drunk', targetId, 'Made ' .. targetName .. ' drunk', 'warning')
        TriggerClientEvent('adminpanel:client:notify', src, 'Made ' .. targetName .. ' drunk', 'success')
    else
        TriggerClientEvent('adminpanel:client:notify', src, 'Player not found', 'error')
    end
end)

-- Mute Player
local mutedPlayers = {}
RegisterNetEvent('adminpanel:server:mutePlayer', function(targetId, muted)
    local src = source
    if not HasPermission(src) then return end
    
    targetId = tonumber(targetId)
    local Target = QBCore.Functions.GetPlayer(targetId)
    
    if Target then
        local targetName = GetTargetName(targetId)
        mutedPlayers[targetId] = muted
        
        -- If using pma-voice
        if GetResourceState('pma-voice') == 'started' then
            exports['pma-voice']:setPlayerMuted(targetId, muted)
        end
        
        local action = muted and 'Muted' or 'Unmuted'
        LogAction(src, action .. ' Player', targetId, targetName .. ' was ' .. action:lower(), 'warning')
        TriggerClientEvent('adminpanel:client:notify', src, targetName .. ' has been ' .. action:lower(), 'success')
        
        if muted then
            TriggerClientEvent('adminpanel:client:notify', targetId, 'You have been muted by an admin', 'error')
        else
            TriggerClientEvent('adminpanel:client:notify', targetId, 'You have been unmuted', 'success')
        end
    else
        TriggerClientEvent('adminpanel:client:notify', src, 'Player not found', 'error')
    end
end)

-- Open Player Inventory (ox_inventory)
RegisterNetEvent('adminpanel:server:openPlayerInventory', function(targetId)
    local src = source
    if not HasPermission(src) then return end
    
    targetId = tonumber(targetId)
    local Target = QBCore.Functions.GetPlayer(targetId)
    
    if Target then
        local targetName = GetTargetName(targetId)
        
        if GetResourceState('ox_inventory') == 'started' then
            local identifier = Target.PlayerData.citizenid
            exports['ox_inventory']:forceOpenInventory(src, 'player', identifier)
            
            LogAction(src, 'Open Inventory', targetId, 'Opened ' .. targetName .. "'s inventory", 'info')
            TriggerClientEvent('adminpanel:client:notify', src, 'Opened ' .. targetName .. "'s inventory", 'success')
        else
            TriggerClientEvent('adminpanel:client:notify', src, 'ox_inventory not found', 'error')
        end
    else
        TriggerClientEvent('adminpanel:client:notify', src, 'Player not found', 'error')
    end
end)

