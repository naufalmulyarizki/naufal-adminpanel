-- Give Car to Player
RegisterNetEvent('adminpanel:server:giveCarToPlayer', function(targetId, vehicle, plate)
    local src = source
    if not HasPermission(src) then return end
    
    targetId = tonumber(targetId)
    local Target = QBCore.Functions.GetPlayer(targetId)
    
    if Target then
        local targetName = GetTargetName(targetId)
        TriggerClientEvent('adminpanel:client:spawnCar', targetId, vehicle, plate)
        
        local plateInfo = plate and (' with plate ' .. plate) or ''
        LogAction(src, 'Give Car', targetId, 'Gave ' .. vehicle .. plateInfo .. ' to ' .. targetName, 'info')
        TriggerClientEvent('adminpanel:client:notify', src, 'Gave ' .. vehicle .. ' to ' .. targetName, 'success')
        Debug('Gave car to:', targetId, vehicle, plate)
    else
        TriggerClientEvent('adminpanel:client:notify', src, 'Player not found', 'error')
    end
