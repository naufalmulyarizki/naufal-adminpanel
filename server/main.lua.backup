-- Open Trunk Inventory (ox_inventory)
RegisterNetEvent('adminpanel:server:openTrunkInventory', function(targetId)
    local src = source
    if not HasPermission(src) then return end
    
    targetId = tonumber(targetId)
    local Target = QBCore.Functions.GetPlayer(targetId)
    
    if Target then
        local targetName = GetTargetName(targetId)
        
        if GetResourceState('ox_inventory') == 'started' then
            -- Get nearest vehicle trunk to target
            TriggerClientEvent('adminpanel:client:openTrunk', targetId, src)
            
            LogAction(src, 'Open Trunk', targetId, 'Opened trunk near ' .. targetName, 'info')
            TriggerClientEvent('adminpanel:client:notify', src, 'Opening trunk inventory...', 'success')
        else
            TriggerClientEvent('adminpanel:client:notify', src, 'ox_inventory not found', 'error')
        end
    else
        TriggerClientEvent('adminpanel:client:notify', src, 'Player not found', 'error')
    end
end)

-- Remove Money from Player
RegisterNetEvent('adminpanel:server:removeMoneyPlayer', function(targetId, amount, moneyType)
    local src = source
    if not HasPermission(src) then return end
    
    targetId = tonumber(targetId)
    amount = tonumber(amount) or 0
    moneyType = moneyType or 'money'
    local Target = QBCore.Functions.GetPlayer(targetId)
    
    if Target then
        local targetName = GetTargetName(targetId)
        
        if moneyType == 'bank' then
            Target.Functions.RemoveMoney('bank', amount, 'admin-panel')
        else
            Target.Functions.RemoveMoney('cash', amount, 'admin-panel')
        end
        
        LogAction(src, 'Remove Money', targetId, 'Removed $' .. amount .. ' (' .. moneyType .. ') from ' .. targetName, 'warning')
        TriggerClientEvent('adminpanel:client:notify', src, 'Removed $' .. amount .. ' from ' .. targetName, 'success')
        TriggerClientEvent('adminpanel:client:notify', targetId, '$' .. amount .. ' was removed from your ' .. moneyType, 'error')
    else
        TriggerClientEvent('adminpanel:client:notify', src, 'Player not found', 'error')
    end
end)

-- Remove Stress
RegisterNetEvent('adminpanel:server:removeStress', function(targetId)
    local src = source
    if not HasPermission(src) then return end
    
    targetId = tonumber(targetId)
    local Target = QBCore.Functions.GetPlayer(targetId)
    
    if Target then
        local targetName = GetTargetName(targetId)
        
        Target.Functions.SetMetaData('stress', 0)
        TriggerClientEvent('adminpanel:client:removeStress', targetId)
        TriggerClientEvent('hud:client:UpdateStress', targetId, 0)
        
        LogAction(src, 'Remove Stress', targetId, 'Removed stress from ' .. targetName, 'info')
        TriggerClientEvent('adminpanel:client:notify', src, 'Removed stress from ' .. targetName, 'success')
        TriggerClientEvent('adminpanel:client:notify', targetId, 'Your stress has been removed', 'success')
    else
        TriggerClientEvent('adminpanel:client:notify', src, 'Player not found', 'error')
    end
end)

