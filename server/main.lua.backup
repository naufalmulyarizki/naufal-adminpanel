-- Spectate Player
RegisterNetEvent('adminpanel:server:spectatePlayer', function(targetId, spectate)
    local src = source
    if not HasPermission(src) then return end
    
    targetId = tonumber(targetId)
    local Target = QBCore.Functions.GetPlayer(targetId)
    
    if Target then
        local targetName = GetTargetName(targetId)
        
        if spectate then
            TriggerClientEvent('adminpanel:client:startSpectate', src, targetId)
            LogAction(src, 'Spectate', targetId, 'Started spectating ' .. targetName, 'info')
        else
            TriggerClientEvent('adminpanel:client:stopSpectate', src)
            LogAction(src, 'Stop Spectate', targetId, 'Stopped spectating ' .. targetName, 'info')
        end
    else
        TriggerClientEvent('adminpanel:client:notify', src, 'Player not found', 'error')
    end
end)

-- Give Clothing Menu
RegisterNetEvent('adminpanel:server:giveClothingMenu', function(targetId)
    local src = source
    if not HasPermission(src) then return end
    
    targetId = tonumber(targetId)
    local Target = QBCore.Functions.GetPlayer(targetId)
    
    if Target then
        local targetName = GetTargetName(targetId)
        
        -- Try different clothing resources
        if GetResourceState('illenium-appearance') == 'started' then
            TriggerClientEvent('illenium-appearance:client:openClothingShop', targetId)
        elseif GetResourceState('qb-clothing') == 'started' then
            TriggerClientEvent('qb-clothing:client:openMenu', targetId)
        elseif GetResourceState('fivem-appearance') == 'started' then
            TriggerClientEvent('fivem-appearance:client:openClothingShop', targetId)
        else
            TriggerClientEvent('adminpanel:client:notify', src, 'No clothing resource found', 'error')
            return
        end
        
        LogAction(src, 'Give Clothing', targetId, 'Opened clothing menu for ' .. targetName, 'info')
        TriggerClientEvent('adminpanel:client:notify', src, 'Opened clothing menu for ' .. targetName, 'success')
    else
        TriggerClientEvent('adminpanel:client:notify', src, 'Player not found', 'error')
    end
end)

-- Revive Player in Radius (helper)
RegisterNetEvent('adminpanel:server:revivePlayerInRadius', function(targetId)
    local src = source
    targetId = tonumber(targetId)
    local Target = QBCore.Functions.GetPlayer(targetId)
    
    if Target then
        -- Use hospital/ambulance job resource if available
        if GetResourceState('hospital') == 'started' then
            TriggerClientEvent('hospital:client:Revive', targetId)
        elseif GetResourceState('qb-ambulancejob') == 'started' then
            TriggerClientEvent('hospital:client:Revive', targetId)
        else
            TriggerClientEvent('adminpanel:client:revive', targetId)
        end
    end
end)

-- Open Trunk by Plate (helper)
RegisterNetEvent('adminpanel:server:openTrunkByPlate', function(adminId, plate)
    local src = source
    
    if GetResourceState('ox_inventory') == 'started' then
        local trunkId = 'trunk_' .. plate:gsub('%s+', '')
        exports['ox_inventory']:forceOpenInventory(adminId, 'trunk', trunkId)
        TriggerClientEvent('adminpanel:client:notify', adminId, 'Opened trunk: ' .. plate, 'success')
    else
        TriggerClientEvent('adminpanel:client:notify', adminId, 'ox_inventory not found', 'error')
    end
end)

-- Export functions
exports('HasPermission', HasPermission)
exports('LogAction', LogAction)
exports('GetPlayersData', GetPlayersData)
