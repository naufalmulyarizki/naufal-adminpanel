local noclipEntity = nil
local noclipSpeed = 1.0
RegisterNUICallback('selfToggle', function(data, cb)
    local option = data.option
    local enabled = data.enabled
    local ped = PlayerPedId()
    
    Debug('Self toggle:', option, enabled)
    
    selfOptions[option] = enabled
    
    if option == 'godMode' then
        SetEntityInvincible(ped, enabled)
        if enabled then
            QBCore.Functions.Notify('God Mode enabled', 'success')
        else
            QBCore.Functions.Notify('God Mode disabled', 'error')
        end
        
    elseif option == 'invisible' then
        SetEntityVisible(ped, not enabled, false)
        if enabled then
            QBCore.Functions.Notify('Invisible enabled', 'success')
        else
            QBCore.Functions.Notify('Invisible disabled', 'error')
        end
        
    elseif option == 'noclip' then
        if enabled then
            noclipEntity = ped
            if IsPedInAnyVehicle(ped, false) then
                noclipEntity = GetVehiclePedIsIn(ped, false)
            end
            FreezeEntityPosition(noclipEntity, true)
            SetEntityCollision(noclipEntity, false, false)
            QBCore.Functions.Notify('NoClip enabled. Use WASD + Shift/Ctrl', 'success')
        else
            if noclipEntity then
                FreezeEntityPosition(noclipEntity, false)
                SetEntityCollision(noclipEntity, true, true)
                noclipEntity = nil
            end
            QBCore.Functions.Notify('NoClip disabled', 'error')
        end
        
    elseif option == 'fastRun' then
        if enabled then
            SetRunSprintMultiplierForPlayer(PlayerId(), 1.49)
            QBCore.Functions.Notify('Fast Run enabled', 'success')
        else
            SetRunSprintMultiplierForPlayer(PlayerId(), 1.0)
            QBCore.Functions.Notify('Fast Run disabled', 'error')
        end
        
    elseif option == 'superJump' then
        if enabled then
            QBCore.Functions.Notify('Super Jump enabled', 'success')
        else
            QBCore.Functions.Notify('Super Jump disabled', 'error')
        end
    elseif option == 'infiniteStamina' then
        if enabled then
            QBCore.Functions.Notify('Infinite Stamina enabled', 'success')
        else
            QBCore.Functions.Notify('Infinite Stamina disabled', 'error')
        end
    elseif option == 'noRagdoll' then
        SetPedCanRagdoll(ped, not enabled)
        if enabled then
            QBCore.Functions.Notify('No Ragdoll enabled', 'success')
        else
            QBCore.Functions.Notify('No Ragdoll disabled', 'error')
        end
    elseif option == 'showBlips' then
        if enabled then
            CreateThread(function()
                while selfOptions.showBlips do
                    for _, playerId in ipairs(GetActivePlayers()) do
                        if playerId ~= PlayerId() then
                            local targetPed = GetPlayerPed(playerId)
                            if targetPed and DoesEntityExist(targetPed) then
                                if not playerBlips[playerId] then
                                    local blip = AddBlipForEntity(targetPed)
                                    SetBlipSprite(blip, 1)
                                    SetBlipColour(blip, 2)
                                    SetBlipScale(blip, 0.8)
                                    SetBlipAsShortRange(blip, false)
                                    BeginTextCommandSetBlipName("STRING")
                                    AddTextComponentString(GetPlayerName(playerId))
                                    EndTextCommandSetBlipName(blip)
                                    playerBlips[playerId] = blip
                                end
                            end
                        end
                    end
                    
                    for playerId, blip in pairs(playerBlips) do
                        local found = false
                        for _, activeId in ipairs(GetActivePlayers()) do
                            if activeId == playerId then found = true break end
                        end
                        if not found then
                            RemoveBlip(blip)
                            playerBlips[playerId] = nil
                        end
                    end
                    
                    Wait(2000)
                end
            end)
            QBCore.Functions.Notify('Player Blips enabled', 'success')
        else
            for playerId, blip in pairs(playerBlips) do
                if DoesBlipExist(blip) then
                    RemoveBlip(blip)
                end
            end
            playerBlips = {}
            QBCore.Functions.Notify('Player Blips disabled', 'error')
        end
    elseif option == 'showPlayerNames' then
        showingNames = enabled
        if enabled then
            CreateThread(function()
                while showingNames do
                    for _, playerId in ipairs(GetActivePlayers()) do
                        if playerId ~= PlayerId() then
                            local targetPed = GetPlayerPed(playerId)
                            if targetPed and DoesEntityExist(targetPed) then
                                local coords = GetEntityCoords(targetPed)
                                local distance = #(GetEntityCoords(PlayerPedId()) - coords)
                                if distance < 100.0 then
                                    local name = GetPlayerName(playerId) .. " [" .. GetPlayerServerId(playerId) .. "]"
                                    SetDrawOrigin(coords.x, coords.y, coords.z + 1.0, 0)
                                    SetTextFont(4)
                                    SetTextScale(0.35, 0.35)
                                    SetTextColour(255, 255, 255, 255)
                                    SetTextOutline()
                                    SetTextCentre(true)
                                    BeginTextCommandDisplayText("STRING")
                                    AddTextComponentSubstringPlayerName(name)
                                    EndTextCommandDisplayText(0.0, 0.0)
                                    ClearDrawOrigin()
                                end
                            end
                        end
                    end
                    Wait(0)
                end
            end)
            QBCore.Functions.Notify('Player Names enabled', 'success')
        else
            QBCore.Functions.Notify('Player Names disabled', 'error')
        end
    end
    
    TriggerServerEvent('adminpanel:server:logAction', 'Self Toggle', nil, option .. ' ' .. (enabled and 'enabled' or 'disabled'))
    cb({ success = true })
end)

-- Heal Self
RegisterNUICallback('healSelf', function(data, cb)
    local ped = PlayerPedId()
    SetEntityHealth(ped, GetEntityMaxHealth(ped))
    SetPedArmour(ped, 100)
    ClearPedBloodDamage(ped)
    QBCore.Functions.Notify('Healed and armored', 'success')
    TriggerServerEvent('adminpanel:server:logAction', 'Heal Self', nil, 'Healed self')
    cb({ success = true })
end)

