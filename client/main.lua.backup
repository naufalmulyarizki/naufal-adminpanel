local QBCore = exports['qb-core']:GetCoreObject()
local isOpen = false
local currentWeather = 'EXTRASUNNY'
local currentHour = 12
local currentMinute = 0
local freezeTime = false
local blackout = false
local selfOptions = {
    godMode = false,
    invisible = false,
    noclip = false,
    infiniteStamina = false,
    noRagdoll = false,
    fastRun = false,
    superJump = false,
    showBlips = false,
    showPlayerNames = false
}

local playerOptions = {
    frozenPlayers = {},
    mutedPlayers = {},
    spectatingPlayer = nil
}

local playerBlips = {}
local showingNames = false

local function Debug(...)
    if Config.Debug then
        print('[AdminPanel:Client]', ...)
    end
end

local function OpenAdminPanel()
    if isOpen then return end
    
    QBCore.Functions.TriggerCallback('adminpanel:server:hasPermission', function(hasPermission, features)
        if not hasPermission then
            QBCore.Functions.Notify(Config.Notifications.noPermission, 'error')
            return
        end
        
        QBCore.Functions.TriggerCallback('adminpanel:server:getPlayers', function(players)
            isOpen = true
            SetNuiFocus(true, true)
            SendNUIMessage({
                action = 'open',
                data = {
                    players = players,
                    selfOptions = selfOptions, 
                    worldOptions = {
                        weather = currentWeather,
                        freezeTime = freezeTime,
                        blackout = blackout
                    },
                    playerOptions = playerOptions, 
                    features = features
                }
            })
            Debug('Admin panel opened with features:', json.encode(features))
        end)
    end)
end

local function CloseAdminPanel()
    if not isOpen then return end
    isOpen = false
    SetNuiFocus(false, false)
    SendNUIMessage({
        action = 'close'
    })
    Debug('Admin panel closed')
end

local function ToggleAdminPanel()
    if isOpen then
        CloseAdminPanel()
    else
        OpenAdminPanel()
    end
end

RegisterCommand(Config.OpenCommand, function()
    ToggleAdminPanel()
end, false)

if Config.OpenKey then
    RegisterKeyMapping(Config.OpenCommand, 'Open Admin Panel', 'keyboard', Config.OpenKey)
end

RegisterNUICallback('close', function(data, cb)
    CloseAdminPanel()
    cb({ success = true })
end)

