RegisterNUICallback('freezePlayer', function(data, cb)
    local playerId = data.playerId
    local frozen = data.frozen
    
    if frozen then
        local found = false
        for _, id in ipairs(playerOptions.frozenPlayers) do
            if id == playerId then found = true break end
        end
        if not found then
            table.insert(playerOptions.frozenPlayers, playerId)
        end
    else
        for i, id in ipairs(playerOptions.frozenPlayers) do
            if id == playerId then
                table.remove(playerOptions.frozenPlayers, i)
                break
            end
        end
    end
    
    TriggerServerEvent('adminpanel:server:freezePlayer', playerId, frozen)
    cb({ success = true })
end)

