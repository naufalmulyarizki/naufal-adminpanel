    end
    
    SetVehicleOnGroundProperly(vehicle)
    
    QBCore.Functions.Notify('Vehicle flipped', 'success')
    TriggerServerEvent('adminpanel:server:logAction', 'Flip Vehicle', nil, 'Flipped vehicle')
